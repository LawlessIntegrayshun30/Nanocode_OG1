# Nanocode API
API_HOST=0.0.0.0
API_PORT=8000
MODEL_SERVER_URL=http://localhost:9000
LOG_LEVEL=INFO

# Security / API limits
MAX_REQUEST_BODY_SIZE=1000000
RATE_LIMIT_PER_MINUTE=60

# Local inference reliability (v1.0)
# Increased default total timeout helps continuity on slower local models.
MODEL_TIMEOUT_SECONDS=180
MODEL_CONNECT_TIMEOUT_SECONDS=10
MODEL_READ_TIMEOUT_SECONDS=180
MODEL_MAX_RETRIES=2
MODEL_RETRY_BACKOFF_SECONDS=0.5
MODEL_RETRY_MAX_BACKOFF_SECONDS=4.0
# Comma-delimited or JSON list both supported.
MODEL_RETRY_ON_STATUS=429,502,503,504

# Optional loop fuse (best-effort idempotency guard; default OFF)
MODEL_IDEMPOTENCY_GUARD_ENABLED=false
MODEL_IDEMPOTENCY_MAX_REPEATS=3
MODEL_IDEMPOTENCY_WINDOW_SECONDS=60

# Optional model-provider settings used by configure_nanocode.sh
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet
CUSTOM_MODEL_BASE_URL=
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_NAME=
